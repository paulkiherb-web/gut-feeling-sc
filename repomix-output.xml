                left: 0,
                right: 0,
                bottom: 0,
                height: `${Math.max(day.real, 8)}%`,
                background: boostaTokens.color.real[400],
              }}
            />
          )}
        </div>
        {day.hasData && (
          <div
            style={{
              position: 'absolute',
