        </p>
      </div>

      {/* Effect bars */}
      <div className="space-y-2">
        {timeline.entries.slice(0, 4).map((entry) => {
          const style = STRENGTH_STYLE[entry.strength];
          const barWidth = Math.max(4, Math.round(((entry.avgEffectSize + 1) / 2) * 100));
