  strain: 0,
  recoveryDebtHours: 0,
};

export const deriveMeals = (events: DomainEvent[]): LoggedMeal[] =>
  sortEvents([...byType(events, 'meal.logged'), ...byType(events, 'scan.completed')])
    .map((event) => ({
