    tone: { register: 'concise', showRationale: false, showImpact: false },
    focusModeActive: false,
    sectionBreathing: 'spacious',
  },

  overloaded: {
    state: 'overloaded',
    density: {
      level: 'minimal',
      maxRecommendations: 1,
      maxInsights: 1,
      maxPredictions: 2,
      spacingScale: 1.2,
      showSecondaryCards: false,
    },
