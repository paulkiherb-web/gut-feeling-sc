    @apply bg-background text-foreground antialiased;
    font-family: 'Outfit', system-ui, -apple-system, sans-serif;
    -webkit-tap-highlight-color: transparent;
    -webkit-touch-callout: none;
    overscroll-behavior: none;
  }
}

@layer utilities {
  /* Premium glass effects */
  .glass {
    @apply backdrop-blur-2xl border border-border/30;
    background: linear-gradient(
      145deg,
      hsl(var(--card) / 0.6),
      hsl(var(--card) / 0.4)
    );
  }

  .glass-strong {
    @apply backdrop-blur-3xl border border-border/20;
    background: linear-gradient(
      145deg,
      hsl(var(--card) / 0.82),
      hsl(var(--card) / 0.65)
    );
  }

  .glass-glow {
    @apply glass;
    box-shadow:
      0 0 50px hsl(var(--glow) / 0.06),
      0 8px 40px hsl(var(--background) / 0.35),
      inset 0 1px 0 hsl(0 0% 100% / 0.06);
  }

  .glass-premium {
    @apply backdrop-blur-3xl border border-border/15;
    background: linear-gradient(
      155deg,
      hsl(var(--card) / 0.85),
      hsl(var(--card) / 0.6),
      hsl(var(--glow-soft) / 0.03)
    );
    box-shadow:
      0 0 60px hsl(var(--glow) / 0.05),
      0 12px 48px hsl(var(--background) / 0.4),
      inset 0 1px 0 hsl(0 0% 100% / 0.08),
      inset 0 -1px 0 hsl(var(--glow) / 0.03);
  }

  /* Premium gradients */
  .gradient-safe {
    background: linear-gradient(135deg, hsl(158 64% 38%), hsl(172 55% 42%));
  }

  .gradient-warning {
    background: linear-gradient(135deg, hsl(36 95% 54%), hsl(28 88% 56%));
  }

  .gradient-danger {
    background: linear-gradient(135deg, hsl(348 72% 52%), hsl(0 68% 48%));
  }

  .gradient-organic {
    background: linear-gradient(
      135deg,
      hsl(158 64% 38%),
      hsl(172 50% 40%),
      hsl(195 48% 42%)
    );
  }

  .gradient-aurora {
    background: linear-gradient(
      135deg,
      hsl(158 64% 38% / 0.12),
      hsl(195 55% 48% / 0.08),
      hsl(270 55% 58% / 0.06),
      hsl(36 92% 54% / 0.08)
    );
  }

  .gradient-premium {
    background: linear-gradient(
      145deg,
      hsl(158 64% 38%),
      hsl(195 50% 40%),
      hsl(230 45% 48%)
    );
  }

  .gradient-deep {
    background: linear-gradient(
      160deg,
      hsl(230 45% 22%),
      hsl(270 40% 18%),
      hsl(195 45% 20%)
    );
  }

  .gradient-glass-warm {
    background: linear-gradient(
      145deg,
      hsl(36 92% 54% / 0.08),
      hsl(var(--card) / 0.7),
      hsl(348 72% 52% / 0.04)
    );
  }

  .gradient-glass-cool {
    background: linear-gradient(
      145deg,
      hsl(195 70% 50% / 0.06),
      hsl(var(--card) / 0.7),
      hsl(270 55% 62% / 0.04)
    );
  }

  /* Glows */
  .scan-glow {
    box-shadow:
      0 0 40px hsl(158 64% 38% / 0.2),
      0 0 80px hsl(158 64% 38% / 0.08),
      0 0 120px hsl(172 55% 42% / 0.04);
  }

  .glow-primary {
    box-shadow: 0 0 30px hsl(var(--primary) / 0.18), 0 0 60px hsl(var(--primary) / 0.06);
  }

  .glow-warm {
    box-shadow: 0 0 30px hsl(var(--glow-warm) / 0.18);
  }

  .glow-soft {
    box-shadow: 0 0 30px hsl(var(--glow-soft) / 0.14);
  }

  .glow-cool {
    box-shadow: 0 0 30px hsl(var(--glow-cool) / 0.14);
  }

  /* Organic shapes */
  .organic-blob {
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
  }

  .organic-blob-2 {
    border-radius: 40% 60% 70% 30% / 40% 70% 30% 60%;
  }

  /* Smooth scrollbar */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Mobile app shell */
  .mobile-screen {
    @apply relative h-full w-full overflow-hidden bg-background;
    max-height: 100dvh;
  }

  .safe-top {
    padding-top: max(env(safe-area-inset-top), 12px);
  }

  .safe-bottom {
    padding-bottom: max(env(safe-area-inset-bottom), 4px);
  }

  /* Native touch feedback */
  .tap-card {
    @apply transition-transform duration-100 active:scale-[0.97];
  }

  /* Segmented control */
  .segmented-control {
    @apply flex gap-1 p-1 rounded-2xl glass;
  }

  .segmented-item {
    @apply flex-1 min-w-0 px-1.5 py-2 rounded-xl text-[clamp(10px,2.8vw,12px)] font-semibold text-center leading-tight transition-all tap-card truncate;
  }

  .segmented-item-active {
    @apply text-primary-foreground shadow-sm;
    background: linear-gradient(135deg, hsl(var(--primary)), hsl(var(--ring)));
  }

  .segmented-item-inactive {
    @apply text-muted-foreground;
  }

  /* Sticky CTA */
  .sticky-cta {
    @apply fixed bottom-[calc(4.5rem+env(safe-area-inset-bottom))] left-4 right-4 z-30;
  }
}

/* Breathing animation for background blobs */
@keyframes breathe {
  0%, 100% { transform: scale(1) translate(0, 0); opacity: 0.4; }
  33% { transform: scale(1.1) translate(5%, -3%); opacity: 0.6; }
  66% { transform: scale(0.95) translate(-3%, 5%); opacity: 0.35; }
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  33% { transform: translateY(-10px) rotate(1deg); }
  66% { transform: translateY(5px) rotate(-0.5deg); }
}

@keyframes morph {
  0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  33% { border-radius: 40% 60% 70% 30% / 40% 70% 30% 60%; }
  66% { border-radius: 50% 50% 40% 60% / 35% 65% 35% 65%; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   INVISIBLE PREMIUM — Utility Layer
   Human-designed. Calm. Editorial. Precise. Trustworthy.
   ═══════════════════════════════════════════════════════════════════════════ */

@layer utilities {

  /* ── Premium Surface System ──────────────────────────────────────────────
     Flat, minimal borders, no heavy shadows, no floating-glass effect.
     Neutral. Not theme-tinted. Consistent across all themes.
  ── */

  .ds-surface-flat {
    background: var(--ds-surface-1-bg);
    border: 1px solid var(--ds-line-1);
  }

  .ds-surface-raised {
    background: var(--ds-surface-1-bg);
    border: 1px solid var(--ds-line-1);
    box-shadow: var(--ds-elev-1);
  }

  .ds-surface-subtle {
    background: var(--ds-surface-3-bg);
  }

  .ds-surface-inset {
    background: var(--ds-surface-2-bg);
    border: 1px solid var(--ds-line-0);
  }

  /* ── Typography Scale ────────────────────────────────────────────────────
     Typography = primary premium signal.
     Responsive sizes. Strong hierarchy. Generous line-height.
  ── */

  .ds-text-display {
    font-family: 'Space Grotesk', 'Outfit', system-ui, sans-serif;
    font-size: clamp(32px, 8vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.04em;
    font-weight: 700;
  }

  .ds-text-hero {
    font-family: 'Space Grotesk', 'Outfit', system-ui, sans-serif;
    font-size: clamp(26px, 6.5vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .ds-text-title {
    font-family: 'Space Grotesk', 'Outfit', system-ui, sans-serif;
    font-size: clamp(20px, 5vw, 24px);
    line-height: 1.2;
    letter-spacing: -0.025em;
    font-weight: 600;
  }

  .ds-text-section {
    font-size: clamp(16px, 4vw, 18px);
    line-height: 1.3;
    letter-spacing: -0.02em;
    font-weight: 600;
  }

  .ds-text-body {
    font-size: 15px;
    line-height: 1.65;
    letter-spacing: -0.01em;
    font-weight: 400;
  }

  .ds-text-secondary {
    font-size: 13px;
    line-height: 1.55;
    letter-spacing: 0em;
    font-weight: 400;
  }

  .ds-text-caption {
    font-size: 11px;
    line-height: 1.45;
    letter-spacing: 0.01em;
    font-weight: 500;
  }

  .ds-text-micro {
    font-size: 9px;
    line-height: 1.3;
    letter-spacing: 0.07em;
    font-weight: 600;
    text-transform: uppercase;
  }

  /* ── Spacing Rhythm ──────────────────────────────────────────────────────
     Section breathing — the primary premium factor.
  ── */

  .ds-section-gap     { gap: var(--ds-space-4); }
  .ds-section-gap-lg  { gap: var(--ds-space-6); }
  .ds-section-gap-xl  { gap: var(--ds-space-8); }

  .ds-content-px      { padding-left: var(--ds-space-5); padding-right: var(--ds-space-5); }
  .ds-content-px-sm   { padding-left: var(--ds-space-4); padding-right: var(--ds-space-4); }

  /* ── Elevation ───────────────────────────────────────────────────────────
     Used sparingly. No heavy shadows.
  ── */

  .ds-elev-0 { box-shadow: var(--ds-elev-0); }
  .ds-elev-1 { box-shadow: var(--ds-elev-1); }
  .ds-elev-2 { box-shadow: var(--ds-elev-2); }
  .ds-elev-3 { box-shadow: var(--ds-elev-3); }

  /* ── Motion ──────────────────────────────────────────────────────────────
     Smooth. Calm. Almost invisible. Responsive.
  ── */

  .ds-transition-fast { transition-duration: var(--ds-duration-fast); transition-timing-function: cubic-bezier(0.4,0,0.2,1); }
  .ds-transition-base { transition-duration: var(--ds-duration-base); transition-timing-function: cubic-bezier(0.4,0,0.2,1); }
  .ds-transition-slow { transition-duration: var(--ds-duration-slow); transition-timing-function: cubic-bezier(0.4,0,0.2,1); }
  .ds-transition-calm { transition-duration: var(--ds-duration-calm); transition-timing-function: cubic-bezier(0.4,0,0.2,1); }

  /* ── Tap feedback (restrained) ───────────────────────────────────────────── */
  .ds-tap { transition: transform 100ms cubic-bezier(0.4,0,0.2,1); }
  .ds-tap:active { transform: scale(0.98); }
  .ds-tap-light:active { transform: scale(0.99); }

  /* ── Accent scope ────────────────────────────────────────────────────────
     Only for CTAs, pills, highlights, focus, indicators.
     NOT for general surfaces or backgrounds.
  ── */

  .ds-accent-bg         { background: hsl(var(--primary)); }
  .ds-accent-bg-subtle  { background: hsl(var(--primary) / 0.10); }
  .ds-accent-bg-muted   { background: hsl(var(--primary) / 0.06); }
  .ds-accent-text       { color: hsl(var(--primary)); }
  .ds-accent-border     { border-color: hsl(var(--primary) / 0.35); }

  /* ── State semantic colors (muted, non-alarming) ─────────────────────── */

  .ds-state-recovery  { color: hsl(var(--ds-state-recovery)); }
  .ds-state-readiness { color: hsl(var(--ds-state-readiness)); }
  .ds-state-warning   { color: hsl(var(--ds-state-warning)); }
  .ds-state-improving { color: hsl(var(--ds-state-improving)); }
  .ds-state-declining { color: hsl(var(--ds-state-declining)); }
  .ds-state-neutral   { color: hsl(var(--ds-state-neutral)); }

  .ds-state-recovery-bg  { background: hsl(var(--ds-state-recovery) / 0.10); }
  .ds-state-readiness-bg { background: hsl(var(--ds-state-readiness) / 0.10); }
  .ds-state-warning-bg   { background: hsl(var(--ds-state-warning) / 0.10); }
  .ds-state-improving-bg { background: hsl(var(--ds-state-improving) / 0.10); }
  .ds-state-declining-bg { background: hsl(var(--ds-state-declining) / 0.10); }
  .ds-state-neutral-bg   { background: hsl(var(--ds-state-neutral) / 0.08); }

  /* ── Calm Hero Surface ───────────────────────────────────────────────────
     Replaces heavy gradient hero backgrounds.
     Dark, calm, premium. Accent tint from theme (subtle, not dominant).
  ── */

  .ds-hero-surface {
    background: hsl(220 30% 10%);
    position: relative;
    overflow: hidden;
  }

  .ds-hero-surface::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 80% 20%,
      hsl(var(--primary) / 0.15) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* ── Editorial text helpers ──────────────────────────────────────────────── */

  .ds-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ds-text-3);
  }

  .ds-label-accent {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--primary) / 0.75);
  }

  /* ── Vertical rhythm for card stacks ─────────────────────────────────────── */

  .ds-stack > * + * { margin-top: var(--ds-space-3); }
  .ds-stack-lg > * + * { margin-top: var(--ds-space-4); }
  .ds-stack-xl > * + * { margin-top: var(--ds-space-5); }

}
